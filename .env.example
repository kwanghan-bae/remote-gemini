# [필독] Gemini CLI Remote Bridge 설정 가이드

# 1. 서버 포트 설정 (기본값: 3000)
# 스마트폰에서 접속할 때 이 포트를 사용합니다.
PORT=3000

# 2. 인증 비밀번호 (필수 설정)
# 보안을 위해 반드시 자신만의 복잡한 비밀번호로 변경하세요.
# 접속 시 URL 뒤에 ?token=내비밀번호 형식으로 사용합니다.
AUTH_TOKEN=your_secure_password_here

# 3. Gemini CLI 실행 경로
# 보통 'gemini'이지만, 특정 경로에 설치했다면 전체 경로를 적어주세요.
# 예: /usr/local/bin/gemini
GEMINI_CLI_PATH=gemini

# 4. 세션 유지 시간 (단위: 밀리초, 기본 5분)
# 5분 = 300000 (5 * 60 * 1000)
SESSION_TIMEOUT=300000
